# =============================================================================
# Django core
# =============================================================================
SECRET_KEY=replace-with-a-unique-secret-key
DEBUG=false
ALLOWED_HOSTS=api.printy.ke,localhost,127.0.0.1

# =============================================================================
# Database
# =============================================================================
DB_NAME=replace-with-database-name
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-database-password
DB_HOST=localhost
DB_PORT=5432
# ENV_DEBUG=true

# =============================================================================
# CORS / CSRF
# =============================================================================
CORS_ALLOWED_ORIGINS=https://printy.ke,https://www.printy.ke,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://printy.ke,https://www.printy.ke,http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Frontend / Email
# =============================================================================
FRONTEND_URL=https://printy.ke
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=replace-with-email-user
EMAIL_HOST_PASSWORD=replace-with-email-app-password
DEFAULT_FROM_EMAIL=Printy <hello.printyke@gmail.com>
ADMIN_NOTIFY_EMAIL=hello.printyke@gmail.com
# mandatory=require email confirmation, optional=send but don't require, none=skip
ACCOUNT_EMAIL_VERIFICATION=mandatory

# =============================================================================
# OAuth social login (optional)
# =============================================================================
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# GITHUB_CLIENT_ID=replace-with-github-client-id
# GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# =============================================================================
# M-Pesa / Daraja
# =============================================================================
MPESA_ENV=sandbox
# Optional override. If omitted, sandbox/production is derived from MPESA_ENV.
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=replace-with-mpesa-consumer-key
MPESA_CONSUMER_SECRET=replace-with-mpesa-consumer-secret
MPESA_SHORTCODE=replace-with-mpesa-shortcode
MPESA_PASSKEY=replace-with-mpesa-passkey
MPESA_CALLBACK_URL=https://api.printy.ke/api/billing/mpesa/callback/
MPESA_TIMEOUT_SECONDS=30
MPESA_ACCOUNT_REFERENCE_DEFAULT=PRINTY
MPESA_TRANSACTION_DESC_DEFAULT=Printy subscription payment
# Only set these if you later add B2C / transaction-status result callbacks.
# MPESA_INITIATOR_NAME=replace-with-mpesa-initiator-name
# MPESA_INITIATOR_PASSWORD=replace-with-mpesa-initiator-password
# MPESA_SECURITY_CREDENTIAL=replace-with-mpesa-security-credential
# MPESA_TIMEOUT_URL=https://api.printy.ke/api/mpesa/timeout/
# MPESA_RESULT_URL=https://api.printy.ke/api/mpesa/result/

# =============================================================================
# Billing retries
# =============================================================================
BILLING_GRACE_PERIOD_DAYS=3
BILLING_RETRY_SCHEDULE_HOURS=6,24,48
