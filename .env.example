# =============================================================================
# Django core
# =============================================================================
SECRET_KEY=replace-with-a-unique-secret-key
DEBUG=false
ALLOWED_HOSTS=api.printy.ke,178.128.206.240,localhost,127.0.0.1

# =============================================================================
# Database (PostgreSQL required; no SQLite fallback)
# =============================================================================
DB_NAME=replace-with-database-name
DB_USER=replace-with-database-user
DB_PASSWORD=replace-with-database-password
DB_HOST=localhost
DB_PORT=5432
# ENV_DEBUG=true

# =============================================================================
# CORS / CSRF - comma-separated list of allowed frontend origins
# =============================================================================
CORS_ALLOWED_ORIGINS=https://printy.ke,https://www.printy.ke,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://printy.ke,https://www.printy.ke,http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Frontend URL (used in email links)
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Email (console backend is default for dev; use SMTP in production)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=replace-with-smtp-username
# EMAIL_HOST_PASSWORD=replace-with-smtp-password
# DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# OAuth social login (optional)
# =============================================================================
# GOOGLE_CLIENT_ID=replace-with-google-client-id
# GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# GITHUB_CLIENT_ID=replace-with-github-client-id
# GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# =============================================================================
# M-Pesa / Daraja (leave blank to skip payments in dev)
# =============================================================================
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke
# MPESA_CONSUMER_KEY=replace-with-mpesa-consumer-key
# MPESA_CONSUMER_SECRET=replace-with-mpesa-consumer-secret
# MPESA_SHORTCODE=replace-with-mpesa-shortcode
# MPESA_PASSKEY=replace-with-mpesa-passkey
# MPESA_INITIATOR_NAME=replace-with-mpesa-initiator-name
# MPESA_SECURITY_CREDENTIAL=replace-with-mpesa-security-credential
# MPESA_STK_CALLBACK_URL=https://api.example.com/api/payments/mpesa/callback/
