# =============================================================================
# Django core
# =============================================================================
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Database (defaults to SQLite when unset)
# =============================================================================
# DB_ENGINE=mysql
# DB_NAME=printshop
# DB_USER=printshop_user
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# =============================================================================
# CORS — comma-separated list of allowed frontend origins
# =============================================================================
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://printy.ke

# =============================================================================
# Frontend URL (used in email links)
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Email (console backend is default for dev; use SMTP in production)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@printy.ke

# =============================================================================
# OAuth social login (optional)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =============================================================================
# M-Pesa / Daraja (leave blank to skip payments in dev)
# =============================================================================
# MPESA_BASE_URL=https://sandbox.safaricom.co.ke
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_INITIATOR_NAME=
# MPESA_SECURITY_CREDENTIAL=
# MPESA_STK_CALLBACK_URL=https://printy.ke/api/payments/mpesa/callback/
