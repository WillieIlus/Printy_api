SECRET_KEY=dev-only-secret-key
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
SITE_DOMAIN=localhost:8000
SITE_NAME=Printy Local

DB_NAME=printy_db
DB_USER=printy_user
DB_PASSWORD=replace-with-local-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

FRONTEND_URL=http://localhost:3000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Printy Local <dev@printy.local>
ADMIN_NOTIFY_EMAIL=dev@printy.local
ACCOUNT_EMAIL_VERIFICATION=mandatory

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=replace-with-sandbox-consumer-key
MPESA_CONSUMER_SECRET=replace-with-sandbox-consumer-secret
MPESA_SHORTCODE=replace-with-sandbox-shortcode
MPESA_PASSKEY=replace-with-sandbox-passkey
MPESA_CALLBACK_URL=https://replace-with-public-tunnel.example/api/payments/mpesa/callback/
MPESA_TIMEOUT_SECONDS=30
MPESA_ACCOUNT_REFERENCE_DEFAULT=PRINTY
MPESA_TRANSACTION_DESC_DEFAULT=Printy payment

BILLING_GRACE_PERIOD_DAYS=3
BILLING_RETRY_SCHEDULE_HOURS=6,24,48
